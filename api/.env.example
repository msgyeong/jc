# Railway PostgreSQL 연결
DATABASE_URL=postgresql://user:password@host:port/database

# JWT 비밀키 (32자 이상 랜덤 문자열 사용)
JWT_SECRET=your-super-secret-key-change-this-in-production

# 환경
NODE_ENV=production

# 포트
PORT=3000

# Web Push VAPID 키 (node api/scripts/generate-vapid-keys.js 로 생성)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ydpjc.org
